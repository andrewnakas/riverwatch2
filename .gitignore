data/cache/
# v14.5c: SNODAS extracts are produced fresh by the workflow's pre-build
# `snodas-extract` job and shipped to shards via artifact. No need to track.
data/snodas_extracts/
benchmarks/results_*.json
# pinned baselines (e.g. baseline_v1.json) are kept in version control
# v15.1: NWM residual models are large pickled LightGBM bundles — once
# we have a real training run we can either commit them (~1-5MB each)
# or stash them on an orphan branch like nwm-archive. For now, until
# the v14.2 archive has 30+ days of history, the dir is empty so we
# ignore it.
data/nwm_residual_models/
# v16 MB-LSTM: the trained checkpoints (~2.4MB each) ARE committed so the
# Pages build can serve the member; the training corpus and archived forcing
# extracts (Daymet corpus, GFS/HRRR forecast pulls — ~550MB) are rebuildable
# and must never go in git.
data/mblstm/corpus/
data/mblstm/gfs_fcst/
data/mblstm/hrrr_fcst/
data/mblstm/corpus_sources.json
dist/
